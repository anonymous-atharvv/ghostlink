<?xml version="1.0" encoding="utf-8"?>
<!-- By design, we exclude all keys, databases, preferences from any backup to enforce local privacy. -->
<backup-rules>
    <include domain="file" path="." />
    <exclude domain="database" path="ghostlink.db" />
    <exclude domain="sharedpref" path="security_prefs.xml" />
    <exclude domain="file" path="signal_keys/" />
</backup-rules>
